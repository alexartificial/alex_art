# Required: get this from @BotFather on Telegram (just send /newbot)
BOT_TOKEN=123456789:AAExampleTokenReplaceMeWithYours

# Optional: IANA timezone name. Defaults to Asia/Kolkata.
# Examples: America/New_York, Europe/London, Asia/Singapore, UTC
TIMEZONE=Asia/Kolkata

# Optional: SQLite file path. Default is ./reminders.db.
# On Railway/Render with a persistent volume, point this at the mount.
# DB_PATH=/data/reminders.db
